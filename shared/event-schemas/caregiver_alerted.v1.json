{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CaregiverAlerted",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "correlation_id", "alert_id", "dose_instance_id", "patient_id", "caregiver_id", "alert_level"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_type": {"const": "CaregiverAlerted"},
    "event_version": {"const": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "alert_id": {"type": "string", "format": "uuid"},
    "dose_instance_id": {"type": "string", "format": "uuid"},
    "patient_id": {"type": "string", "format": "uuid"},
    "caregiver_id": {"type": "string", "format": "uuid"},
    "alert_level": {"type": "integer", "minimum": 1}
  }
}
