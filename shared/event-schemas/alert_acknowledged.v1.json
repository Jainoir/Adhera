{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AlertAcknowledged",
  "type": "object",
  "required": ["event_id", "event_type", "event_version", "occurred_at", "correlation_id", "alert_id", "caregiver_id"],
  "properties": {
    "event_id": {"type": "string", "format": "uuid"},
    "event_type": {"const": "AlertAcknowledged"},
    "event_version": {"const": 1},
    "occurred_at": {"type": "string", "format": "date-time"},
    "correlation_id": {"type": "string", "format": "uuid"},
    "alert_id": {"type": "string", "format": "uuid"},
    "caregiver_id": {"type": "string", "format": "uuid"},
    "acknowledgement_note": {"type": "string"}
  }
}
