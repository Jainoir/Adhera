# Copy to .env for local development. Never commit real secrets.

# --- Shared service settings (shared/config.BaseServiceSettings) ---
# Each service overrides SERVICE_NAME itself; set the rest per process.
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Per-service database (asyncpg driver, one database per service):
#   identity | medication | notification
DATABASE_URL=postgresql+asyncpg://adhera:adhera_dev_password@localhost:5432/identity
# Redis databases by convention: 0=gateway, 1=identity, 2=medication, 3=notification
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://adhera:adhera_dev_password@localhost:5672//

# --- docker-compose infrastructure bootstrap ---
POSTGRES_USER=adhera
POSTGRES_PASSWORD=adhera_dev_password

# --- API gateway: downstream service URLs ---
IDENTITY_SERVICE_URL=http://localhost:8001
MEDICATION_SERVICE_URL=http://localhost:8002
NOTIFICATION_SERVICE_URL=http://localhost:8003

# --- Auth (used from Phase 1 on) ---
JWT_SECRET=change-me-in-production
